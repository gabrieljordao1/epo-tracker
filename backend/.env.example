# ============================
# EPO Tracker — Environment Config
# ============================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Environment: development | staging | production
ENVIRONMENT=development

# Database
# Local dev (SQLite): sqlite+aiosqlite:///:memory:
# Production (PostgreSQL): postgresql+asyncpg://user:password@host:5432/epo_tracker
DATABASE_URL=sqlite+aiosqlite:///:memory:
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# JWT — auto-generated in dev, MUST be set in production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI API Keys (optional — enables AI email parsing)
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# Email Sending (Resend)
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=notifications@epotracker.com

# Gmail OAuth (for email sync)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/email/oauth/callback

# App
APP_NAME=EPO Tracker
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
DEBUG=false
LOG_LEVEL=INFO

# CORS (comma-separated)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
